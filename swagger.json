{
  "openapi": "3.0.4",
  "info": {
    "title": "MovieFlix API",
    "description": "API para gerenciar filmes",
    "version": "1.0.0"
  },
  "paths": {
    "/movies": {
      "get": {
        "tags": ["Filmes"],
        "summary": "Listar todos os filmes",
        "description": "Retorna uma lista de todos os filmes ordenados por título",
        "operationId": "listAllMovies",
        "responses": {
          "200": {
            "description": "Lista de filmes retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro ao buscar os filmes.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Filmes"],
        "summary": "Cadastrar um novo filme",
        "description": "Cadastra um novo filme no banco de dados",
        "operationId": "createMovie",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMovieRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Filme cadastrado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "409": {
            "description": "Já existe um filme cadastrado com esse título.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao cadastrar filme.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/movies/id/{id}": {
      "get": {
        "tags": ["Filmes"],
        "summary": "Buscar filme por ID",
        "description": "Retorna um filme específico pelo seu ID",
        "operationId": "getMovieById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do filme",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filme encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Movie"
                }
              }
            }
          },
          "404": {
            "description": "Filme não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao buscar filme por ID",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/movies/genres/{genreName}": {
      "get": {
        "tags": ["Filmes"],
        "summary": "Buscar filmes por gênero",
        "description": "Retorna todos os filmes de um gênero específico",
        "operationId": "getMoviesByGenre",
        "parameters": [
          {
            "name": "genreName",
            "in": "path",
            "description": "Nome do gênero",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filmes encontrados",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Nenhum filme foi encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao filtrar filmes por gênero.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/movies/languages/{languageName}": {
      "get": {
        "tags": ["Filmes"],
        "summary": "Buscar filmes por linguagem",
        "description": "Retorna todos os filmes de uma linguagem específica",
        "operationId": "getMoviesByLanguage",
        "parameters": [
          {
            "name": "languageName",
            "in": "path",
            "description": "Nome da linguagem",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filmes encontrados",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Movie"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Nenhum filme foi encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao filtrar filmes por linguagem.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/movies/{id}": {
      "put": {
        "tags": ["Filmes"],
        "summary": "Alterar cadastro um filme",
        "description": "Altera os dados de um filme específico",
        "operationId": "updateMovie",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do filme",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateMovieRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Filme alterado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "404": {
            "description": "Filme não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao atualizar o registro do filme",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Filmes"],
        "summary": "Deletar um filme",
        "description": "Remove um filme específico do banco de dados",
        "operationId": "deleteMovie",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do filme",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Filme deletado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "404": {
            "description": "Filme não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao deletar filme.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/genres": {
      "get": {
        "tags": ["Gêneros"],
        "summary": "Listar todos os gêneros",
        "description": "Retorna uma lista de todos os gêneros cadastrados",
        "operationId": "listAllGenres",
        "responses": {
          "200": {
            "description": "Lista de gêneros retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Genre"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro ao buscar os gêneros.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Gêneros"],
        "summary": "Cadastra um novo gênero",
        "description": "Cadastra um novo gênero no banco de dados",
        "operationId": "createGenre",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateGenreRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Gênero cadastrado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "O nome do gênero é obrigatório.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "409": {
            "description": "Já existe um gênero cadastrado com esse título.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao cadastrar gênero.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/genres/{id}": {
      "put": {
        "tags": ["Gêneros"],
        "summary": "Atualizar um gênero",
        "description": "Atualiza os dados de um gênero específico",
        "operationId": "updateGenre",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do gênero",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateGenreRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gênero alterado com sucesso.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "O nome do gênero é obrigatório.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "404": {
            "description": "Gênero não encontrado.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "409": {
            "description": "Este nome de gênero já existe.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Houve um problema ao atualizar o gênero.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Gêneros"],
        "summary": "Deletar um gênero",
        "description": "Remove um gênero específico do banco de dados",
        "operationId": "deleteGenre",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID do gênero",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Gênero excluído com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "404": {
            "description": "Gênero não encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao excluir gênero",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/languages": {
      "get": {
        "tags": ["Linguagens"],
        "summary": "Listar todas as linguagens",
        "description": "Retorna uma lista de todas as linguagens ordenadas por nome",
        "operationId": "listAllLanguages",
        "responses": {
          "200": {
            "description": "Lista de linguagens retornada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Language"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro ao buscar linguagens",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Linguagens"],
        "summary": "Criar uma nova linguagem",
        "description": "Cria uma nova linguagem no banco de dados",
        "operationId": "createLanguage",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateLanguageRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Linguagem cadastrada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "Nome da linguagem é obrigatório",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "409": {
            "description": "Linguagem com este nome já existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao cadastrar linguagem",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    },
    "/languages/{id}": {
      "put": {
        "tags": ["Linguagens"],
        "summary": "Atualizar uma linguagem",
        "description": "Atualiza os dados de uma linguagem específica",
        "operationId": "updateLanguage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID da linguagem",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLanguageRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Linguagem alterada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "400": {
            "description": "ID inválido ou nome obrigatório",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "404": {
            "description": "Linguagem não encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "409": {
            "description": "Nome de linguagem já existe",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao atualizar linguagem",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Linguagens"],
        "summary": "Deletar uma linguagem",
        "description": "Remove uma linguagem específica do banco de dados",
        "operationId": "deleteLanguage",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID da linguagem",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Linguagem excluída com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                }
              }
            }
          },
          "404": {
            "description": "Linguagem não encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          },
          "500": {
            "description": "Erro ao excluir linguagem",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorMessage"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Genre": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "ID único do gênero"
          },
          "name": {
            "type": "string",
            "description": "Nome do gênero"
          }
        },
        "example": {
          "id": 1,
          "name": "Ação"
        }
      },
      "Language": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "ID único da linguagem"
          },
          "name": {
            "type": "string",
            "description": "Nome da linguagem"
          }
        },
        "example": {
          "id": 1,
          "name": "Português"
        }
      },
      "Movie": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "ID único do filme"
          },
          "title": {
            "type": "string",
            "description": "Título do filme"
          },
          "release_date": {
            "type": "string",
            "format": "date",
            "description": "Data de lançamento do filme"
          },
          "genre_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID do gênero"
          },
          "language_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID da linguagem"
          },
          "oscar_count": {
            "type": "integer",
            "format": "int32",
            "description": "Número de prêmios Oscar"
          },
          "genres": {
            "$ref": "#/components/schemas/Genre"
          },
          "languages": {
            "$ref": "#/components/schemas/Language"
          }
        },
        "example": {
          "title": "Título",
          "release_date": "2010-07-16",
          "genre_id": 1,
          "language_id": 1,
          "oscar_count": 4,
          "genres": {
            "id": 1,
            "name": "Ficção Científica"
          },
          "languages": {
            "id": 1,
            "name": "Inglês"
          }
        }
      },
      "CreateMovieRequest": {
        "type": "object",
        "required": ["title", "genre_id", "language_id"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Título do filme"
          },
          "genre_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID do gênero"
          },
          "language_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID da linguagem"
          },
          "release_date": {
            "type": "string",
            "format": "date",
            "description": "Data de lançamento"
          },
          "oscar_count": {
            "type": "integer",
            "format": "int32",
            "description": "Número de Oscars"
          }
        },
        "example": {
          "title": "Título",
          "genre_id": 1,
          "language_id": 1,
          "release_date": "2025-05-03",
          "oscar_count": 1 
        }
      },
      "UpdateMovieRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "Título do filme"
          },
          "genre_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID do gênero"
          },
          "language_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID da linguagem"
          },
          "release_date": {
            "type": "string",
            "format": "date",
            "description": "Data de lançamento"
          },
          "oscar_count": {
            "type": "integer",
            "format": "int32",
            "description": "Número de Oscars"
          }
        },
        "example": {
          "title": "Inception",
          "oscar_count": 5
        }
      },
      "CreateGenreRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome do gênero"
          }
        },
        "example": {
          "name": "Ação"
        }
      },
      "UpdateGenreRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Nome do gênero"
          }
        },
        "example": {
          "name": "Ação e Aventura"
        }
      },
